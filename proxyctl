#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_PATH="$ROOT_DIR/scripts/proxyctl.py"

if command -v python3 >/dev/null 2>&1; then
  exec python3 "$SCRIPT_PATH" "$@"
fi

if ! command -v docker >/dev/null 2>&1; then
  echo "error: python3 not found and docker not found; install one of them" >&2
  exit 1
fi

exec docker run --rm \
  -u "$(id -u):$(id -g)" \
  -v "$ROOT_DIR:/workspace" \
  -w /workspace \
  python:3.12-alpine \
  python /workspace/scripts/proxyctl.py "$@"
